# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=tutorconnect_nepal
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Cloudinary (leave blank to store media files locally instead)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT
JWT_SECRET_KEY=your-jwt-secret-key

# Email (for password reset, verification)
# Leave EMAIL_BACKEND on the console backend to print OTPs/emails to the
# terminal during development. Switch to the smtp backend and fill in real
# credentials below to actually deliver email.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@tutorconnectnepal.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Payment Gateways
# Leave these blank during local development - payment verification will use
# a safe DEBUG-only manual-confirm fallback instead of calling a real gateway.
# Fill in real sandbox/production credentials before deploying, since real
# API calls are made once these are non-empty.
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=
KHALTI_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (leave blank to disable "Sign in with Google")
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Push Notifications (leave blank to disable FCM push; in-app notifications
# still work without this)
FCM_SERVER_KEY=
FCM_SENDER_ID=

# Sentry (Error Tracking) - leave blank to disable
SENTRY_DSN=

# API
API_VERSION=v1
